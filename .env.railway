# Solana MEV Agent - Railway Env
# Set these as Railway environment variables

# Solana RPC
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Jito Block Engine (Frankfurt for mainnet)
JITO_BLOCK_ENGINE_URL=https://frankfurt.mainnet.block-engine.jito.wtf
JITO_AUTH_KEYPAIR_PATH=.keypair/auth-id.json

# Base64 of JSON keypair array: base64(JSON.stringify([213,3,...,17]))
JITO_AUTH_KEYPAIR_

# Agent Config
AGENT_ID=3325
AGENT_NAME=Solana MEV Agent
AGENT_VERSION=2.0.0-a2mcp

# x402 Payment (OKX Payment Standard) - set to false initially for testing
X402_ENABLED=false
X402_WALLET=8ifrorg6DFECBXFA6fikQ5YkZAhihcqCi72A9shiuuxU

# Pricing (USDT)
PRICE_PER_BUNDLE=10
PRICE_PER_ANALYSIS=5
MIN_TIP_LAMPORTS=1000

# Debug
DEBUG=true
