# Solana Configuration
RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_CLUSTER=mainnet-beta
SOLANA_COMMITMENT=confirmed

# Yellowstone gRPC Streaming (SolInfra - OPTIONAL)
# Leave blank to use HTTP polling fallback (400ms interval)
# Get credentials from https://solinfra.dev
YELLOWSTONE_ENDPOINT=fra.grpc.solinfra.dev:443
YELLOWSTONE_TOKEN=your-solinfra-grpc-token-here

# Keypair Configuration
# Path to your Solana keypair (create with: npx tsx scripts/generate-keypair.ts)
AUTH_KEYPAIR_PATH=./keypairs/devnet.json

# For mainnet testing:
# AUTH_KEYPAIR_PATH=./keypairs/mainnet.json

# Yellowstone gRPC Streaming (SolInfra - OPTIONAL)
# Leave blank to use HTTP polling fallback
# Get credentials from https://solinfra.dev
YELLOWSTONE_ENDPOINT=fra.grpc.solinfra.dev:443
YELLOWSTONE_TOKEN=your-solinfra-grpc-token-here

# Jito Configuration
BLOCK_ENGINE_URL=mainnet.block-engine.jito.wtf
GEYSER_URL=mainnet.geyser.jito.wtf:443
GEYSER_ACCESS_TOKEN=your-jito-access-token-here
AUTH_KEYPAIR_PATH=./keypair.json
BUNDLE_TRANSACTION_LIMIT=5

# Accounts & Programs to Monitor (comma-separated)
ACCOUNTS_OF_INTEREST=
PROGRAMS_OF_INTEREST=

# Transaction Configuration
PRIORITY_FEE=10000
COMPUTE_UNIT_LIMIT=200000

# AI Agent Configuration (DeepSeek)
# Get API key from: https://platform.deepseek.com/
AI_API_KEY=sk-your-deepseek-api-key-here
AI_MODEL=deepseek-chat
# Alternative: deepseek-reasoner (for complex reasoning)

# Application Configuration
LOG_LEVEL=info
NODE_ENV=development
