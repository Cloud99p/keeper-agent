# Keeper Agent — Environment Configuration

# === Solana / Jito (existing) ===
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
JITO_BLOCK_ENGINE_URL=frankfurt.mainnet.block-engine.jito.wtf:443
JITO_AUTH_KEYPAIR_PATH=.keypair/auth-id.json
JITO_AUTH_KEYPAIR_B64=

# === KeeperHub MCP Client (new) ===
KEEPERHUB_API_KEY=kh_your_api_key_here

# === Ethereum / EVM (new — for KeeperHub execution) ===
ETH_RPC_URL=https://base-rpc.publicnode.com
ETH_PRIVATE_KEY=your_ethereum_private_key_here
ETH_WALLET_ADDRESS=0xYourEthereumAddress

# === Server ===
PORT=8080
AGENT_ID=keeper-agent
AGENT_NAME="Keeper Agent"
DEBUG=false

# === Pricing ===
PRICE_PER_BUNDLE=1
PRICE_PER_ANALYSIS=1

# === x402 Legacy (optional) ===
X402_WALLET=
