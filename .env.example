# Solana Transaction Stack - Environment Configuration (PRODUCTION-GRADE)
# Copy this file to .env and fill in your values

# =============================================================================
# YELLOWSTONE gRPC CONFIGURATION
# =============================================================================
# Triton's Yellowstone gRPC endpoint for real-time slot streaming
# 
# Devnet: Use standard RPC (gRPC not available on devnet)
# Mainnet: Use Triton's gRPC endpoint for production
#
# For production, use: https://api.rpcpool.com:443 (with auth token)
# For devnet testing: Standard RPC works fine
YELLOWSTONE_RPC_URL=https://api.devnet.solana.com

# Authentication token for Yellowstone gRPC (required for mainnet production)
# Get from https://triton.one/rpc-endpoints/
# Leave empty for devnet testing
YELLOWSTONE_AUTH_TOKEN=

# =============================================================================
# JITO BLOCK ENGINE CONFIGURATION
# =============================================================================
# Jito Block Engine endpoint for bundle submission
# 
# Devnet: https://devnet.block-engine.jito.wtf
# Mainnet: https://mainnet.block-engine.jito.wtf
# Amsterdam: https://amsterdam.mainnet.block-engine.jito.wtf
# Frankfurt: https://frankfurt.mainnet.block-engine.jito.wtf
# Tokyo: https://tokyo.mainnet.block-engine.jito.wtf
# New York: https://ny.mainnet.block-engine.jito.wtf
JITO_BLOCK_ENGINE_URL=https://devnet.block-engine.jito.wtf

# Path to your Solana keypair for Jito authentication
# This keypair signs bundle submissions and pays for transactions
# 
# IMPORTANT: Use separate keypairs for devnet and mainnet!
# Devnet: Generate with `solana-keygen new -o devnet.json`
# Mainnet: Export from your wallet (NEVER commit to git!)
JITO_AUTH_KEYPAIR_PATH=/mnt/data/openclaw/workspace/.openclaw/workspace/solana-tx-stack/.keypair/devnet.json

# Alternative: Paste keypair as array (for development only, NOT for mainnet)
# JITO_AUTH_KEYPAIR=[1,2,3,...,64]

# =============================================================================
# SOLANA RPC CONFIGURATION
# =============================================================================
# Solana RPC endpoint for blockhash fetching and transaction status
# 
# Devnet: https://api.devnet.solana.com
# Mainnet: https://api.mainnet-beta.solana.com (or your private RPC)
# Production: Use dedicated RPC (Helius, Triton, QuickNode, etc.)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Commitment level for confirmations
# Options: processed, confirmed, finalized
# 
# processed: Fastest, can reorg (risky)
# confirmed: Fast + safe (recommended for trading)
# finalized: Slowest, safest (for final settlement)
SOLANA_COMMITMENT=confirmed

# =============================================================================
# FAILURE AGENT CONFIGURATION
# =============================================================================
# Maximum retry attempts before giving up
AGENT_MAX_RETRIES=3

# Minimum confidence threshold for agent to attempt retry (0.0 - 1.0)
# Below this threshold, agent will abort instead of retry
AGENT_MIN_CONFIDENCE=0.6

# Enable verbose agent reasoning logs
# Set to false in production to reduce log noise
AGENT_VERBOSE=true

# =============================================================================
# BUNDLE CONFIGURATION
# =============================================================================
# Tip calculation percentile (e.g., 0.75 = 75th percentile of recent tips)
# Higher = more aggressive tipping, lower = cheaper but may fail
TIP_PERCENTILE=0.75

# Congestion multiplier factor (higher = more aggressive tipping during congestion)
# Formula: finalTip = baseTip * (1.0 + skipRate * CONGESTION_MULTIPLIER)
CONGESTION_MULTIPLIER=0.5

# Minimum tip in lamports (safety floor, overrides calculation if too low)
# Devnet: 1000 is fine
# Mainnet: 10000+ recommended for competitive bundles
MIN_TIP_LAMPORTS=1000

# Maximum tip in lamports (safety ceiling to prevent overpaying)
# Devnet: 100000 is fine
# Mainnet: Adjust based on your risk tolerance
MAX_TIP_LAMPORTS=100000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Path to lifecycle log file
# Contains full bundle history with agent reasoning for each failure
LIFECYCLE_LOG_PATH=./lifecycle_log.json

# Enable debug logging
# Set to false in production for cleaner logs
DEBUG=true

# =============================================================================
# PRODUCTION CHECKLIST
# =============================================================================
# Before deploying to mainnet:
# 
# [ ] 1. Update YELLOWSTONE_RPC_URL to production gRPC endpoint
# [ ] 2. Set YELLOWSTONE_AUTH_TOKEN from Triton
# [ ] 3. Update JITO_BLOCK_ENGINE_URL to mainnet endpoint
# [ ] 4. Generate NEW mainnet keypair (NEVER reuse devnet keys!)
# [ ] 5. Fund mainnet keypair with SOL (for tx fees + tips)
# [ ] 6. Set SOLANA_RPC_URL to dedicated RPC (not public endpoint)
# [ ] 7. Increase MIN_TIP_LAMPORTS to 10000+ for competitiveness
# [ ] 8. Set DEBUG=false and AGENT_VERBOSE=false
# [ ] 9. Set file permissions: chmod 600 .keypair/mainnet.json
# [ ] 10. Test with small amounts first!
# 
# =============================================================================
# SECURITY NOTES
# =============================================================================
# - NEVER commit .env file with real values to git
# - NEVER commit keypair files to git (already in .gitignore)
# - Store keypairs securely with chmod 600 permissions
# - Rotate API tokens regularly
# - Use separate keypairs for devnet and mainnet
# - Never share your mainnet private key with anyone
# - Consider using a hardware wallet for mainnet funds
