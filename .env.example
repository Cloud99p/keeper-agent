# ===== Solana RPC =====
SOLANA_RPC_URL=https://fra.rpc.solinfra.dev/sol?api_key=your-solinfra-api-key
SOLANA_COMMITMENT=confirmed

# ===== Yellowstone gRPC (Solinfra) =====
YELLOWSTONE_RPC_URL=https://fra.rpc.solinfra.dev/sol?api_key=your-solinfra-api-key
YELLOWSTONE_AUTH_TOKEN=

# ===== Jito Block Engine =====
JITO_BLOCK_ENGINE_URL=https://mainnet.block-engine.jito.wtf
JITO_AUTH_KEYPAIR_PATH=./keypairs/mainnet.json
BUNDLE_TRANSACTION_LIMIT=5

# ===== AI Agent =====
AI_API_KEY=sk-your-deepseek-api-key
AI_MODEL=deepseek-chat

# ===== Transaction Config =====
MIN_TIP_LAMPORTS=1000
DEBUG=true

# ===== A2MCP Server (OKX.AI) =====
PORT=8080
AGENT_ID=3325
AGENT_NAME=Solana MEV Agent
AGENT_VERSION=2.0.0-a2mcp

# ===== A2MCP Pricing =====
PRICE_PER_BUNDLE=10
PRICE_PER_ANALYSIS=5

# ===== x402 Payments (OnchainOS) =====
X402_ENABLED=false
X402_WALLET=
