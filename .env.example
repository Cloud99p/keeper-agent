# Solana Transaction Stack - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# YELLOWSTONE gRPC CONFIGURATION
# =============================================================================
# Triton's Yellowstone gRPC endpoint for real-time slot streaming
# Devnet: Use the devnet gRPC endpoint
# Mainnet: mainnet.rpc.jito.wtf (requires auth token)
YELLOWSTONE_RPC_URL=https://api.devnet.solana.com

# Authentication token for Yellowstone gRPC (required for mainnet)
# Get from https://triton.one/rpc-endpoints/
YELLOWSTONE_AUTH_TOKEN=

# =============================================================================
# JITO BLOCK ENGINE CONFIGURATION
# =============================================================================
# Jito Block Engine endpoint
# Devnet: https://devnet.block-engine.jito.wtf
# Mainnet: https://mainnet.block-engine.jito.wtf
JITO_BLOCK_ENGINE_URL=https://devnet.block-engine.jito.wtf

# Path to your Solana keypair for Jito authentication
# This keypair signs bundle submissions
JITO_AUTH_KEYPAIR_PATH=/path/to/your/keypair.json

# Alternative: paste keypair as array (for development only)
# JITO_AUTH_KEYPAIR=[1,2,3,...,64]

# =============================================================================
# SOLANA RPC CONFIGURATION
# =============================================================================
# Solana RPC endpoint for blockhash fetching and transaction status
# Devnet: https://api.devnet.solana.com
# Mainnet: https://api.mainnet-beta.solana.com (or your private RPC)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Commitment level for confirmations
# Options: processed, confirmed, finalized
SOLANA_COMMITMENT=confirmed

# =============================================================================
# FAILURE AGENT CONFIGURATION
# =============================================================================
# Maximum retry attempts before giving up
AGENT_MAX_RETRIES=3

# Minimum confidence threshold for agent to attempt retry (0.0 - 1.0)
# Below this threshold, agent will abort instead of retry
AGENT_MIN_CONFIDENCE=0.6

# Enable verbose agent reasoning logs
AGENT_VERBOSE=true

# =============================================================================
# BUNDLE CONFIGURATION
# =============================================================================
# Tip calculation percentile (e.g., 0.75 = 75th percentile of recent tips)
TIP_PERCENTILE=0.75

# Congestion multiplier factor (higher = more aggressive tipping during congestion)
CONGESTION_MULTIPLIER=0.5

# Minimum tip in lamports (safety floor, overrides calculation if too low)
MIN_TIP_LAMPORTS=1000

# Maximum tip in lamports (safety ceiling)
MAX_TIP_LAMPORTS=100000

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
# Path to lifecycle log file
LIFECYCLE_LOG_PATH=./lifecycle_log.json

# Enable debug logging
DEBUG=true

# =============================================================================
# SECURITY NOTES
# =============================================================================
# - Never commit .env file with real values
# - Store keypairs securely, use file permissions (chmod 600)
# - Rotate API tokens regularly
# - Use separate keypairs for devnet and mainnet
